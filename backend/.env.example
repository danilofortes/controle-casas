# Conexão com o PostgreSQL do Supabase (use o driver asyncpg).
# Exemplo (conexão direta):
#   postgresql+asyncpg://postgres:SUA_SENHA@db.<ref>.supabase.co:5432/postgres
# Exemplo (pooler/pgBouncer - recomendado em serverless):
#   postgresql+asyncpg://postgres.<ref>:SUA_SENHA@aws-0-<regiao>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/controle_casas

# Senha única compartilhada para acessar o sistema (Requisito 1).
APP_SENHA=troque-esta-senha

# Segredo usado para assinar o token JWT de sessão (HS256). Use uma string longa e aleatória.
APP_SESSION_SECRET=troque-este-segredo-bem-grande-e-aleatorio

# (Opcional) Validade do token de sessão em minutos. Padrão: 43200 (30 dias).
APP_SESSION_EXPIRE_MINUTES=43200

# Origens permitidas para CORS, separadas por vírgula. NÃO use "*" em produção
# junto com cookies/credenciais. Em produção use apenas o domínio do frontend.
APP_CORS_ORIGINS=https://controle-casas.vercel.app,http://localhost:5173

# Ambiente da aplicação. Use "production" em produção (padrão) ou "dev"/"test"
# localmente para tolerar os secrets default acima durante o desenvolvimento.
APP_ENV=development
